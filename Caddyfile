scheme-saathi-agent.prods.live {
 
    tls /etc/caddy/origin.pem /etc/caddy/origin.key

    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    reverse_proxy schemesaathi-agent:8080 {
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
            read_timeout 30s
            write_timeout 30s
        }
    }
}

scheme-saathi.prods.live {

    tls /etc/caddy/origin.pem /etc/caddy/origin.key

    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    reverse_proxy schemesaathi-app:3000
}