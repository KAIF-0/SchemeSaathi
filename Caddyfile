scheme-saathi-agent.prods.live {
    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    reverse_proxy schemesathi-backend:8080 {
        transport http {
            dial_timeout 5s
            response_header_timeout 30s
            read_timeout 30s
            write_timeout 30s
        }
    }
}